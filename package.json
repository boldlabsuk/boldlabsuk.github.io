{
  "name": "bold_website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "check": "biome ci . && npm test && npm run build",
    "check:biome": "biome ci .",
    "dev": "vite",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "build": "tsc -b && vite build && node scripts/generate-static-routes.mjs",
    "lint": "biome lint .",
    "profile-cropper": "node scripts/profile-cropper.mjs",
    "preview": "vite preview",
    "sandcastle": "tsx .sandcastle/main.mts",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.10.0",
    "@biomejs/biome": "^2.5.1",
    "@commander-js/extra-typings": "^15.0.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "commander": "^15.0.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  }
}
